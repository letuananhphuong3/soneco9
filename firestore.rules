rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == 'letuananhphuong20@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(productId);
    }

    // Certificates
    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(certificateId);
    }

    // Dealers
    match /dealers/{dealerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(dealerId);
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(projectId);
    }
  }
}
